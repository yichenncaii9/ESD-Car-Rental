# ==========================================
# ESD Rental Car Service — Environment Keys
# ==========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env or firebase-service-account.json to git.

# Firebase (required for all Firestore-connected services)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Stripe (required for stripe_wrapper)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# OpenAI (required for openai_wrapper)
OPENAI_API_KEY=sk-...

# Twilio (required for twilio_wrapper)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1234567890
TWILIO_SERVICE_TEAM_NUMBER=+6591234567

# Google Maps (required for googlemaps_wrapper and frontend)
GOOGLE_MAPS_API_KEY=AIza...

# RabbitMQ (internal — defaults work for Docker Compose)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
